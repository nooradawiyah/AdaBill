<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Bill"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E8B57"
            android:gravity="center"
            android:layout_marginBottom="30dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#F8F9FA">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Month"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerMonth"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/spinner_background"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Electricity Usage (kWh)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editTextUnit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:hint="Enter 1 - 1000 kWh"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rebate Percentage"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/seekBarRebate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:progressTint="#2E8B57"
                    android:thumbTint="#2E8B57"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textViewRebateValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rebate: 0%"
                    android:textSize="14sp"
                    android:textColor="#2E8B57"
                    android:gravity="center"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#F8F9FA">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CALCULATION RESULT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2E8B57"
                    android:gravity="center"
                    android:layout_marginBottom="15dp" />

                <TextView
                    android:id="@+id/textViewTotalCharges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Charges: RM0.00"
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:background="#E8F5E9"
                    android:textColor="#333333"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/textViewFinalCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Final Cost: RM0.00"
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:background="#E0F2F1"
                    android:textColor="#2E8B57"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonUpdate"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="UPDATE"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/buttonCancel"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="CANCEL"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>